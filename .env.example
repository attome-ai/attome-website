# Config is loaded from config.json (production) or config.debug.json (debug).
# Use APP_ENV=debug to load config.debug.json.
# Use CONFIG_FILE=/path/to/config.json for an explicit path.
#
# Secrets referenced as ${VAR} in the JSON files are expanded from env vars.
# Set these before running in production:

JWT_SECRET=change_me_use_openssl_rand_hex_64
SMTP_PASSWORD=your_sendgrid_api_key
GOOGLE_AI_API_KEY=your_google_ai_key
OAUTH_GOOGLE_CLIENT_ID=your_google_client_id
OAUTH_GOOGLE_CLIENT_SECRET=your_google_client_secret

# LLM providers (only set the ones you use)
LLM_OPENAI_API_KEY=
LLM_ANTHROPIC_API_KEY=
LLM_DEEPSEEK_API_KEY=
LLM_MISTRAL_API_KEY=
LLM_XAI_API_KEY=
LLM_ZHIPU_API_KEY=
LLM_ALIBABA_API_KEY=
LLM_CEREBRAS_API_KEY=

# External AI generation APIs
BFL_API_KEY=
SEEDANCE_API_KEY=

# Logging
RUST_LOG=info,tower_http=debug
