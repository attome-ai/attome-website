# Copy to .env and fill in values before running.
# When running in Docker, DB_HOST/REDIS_HOST must be host.docker.internal (Windows/Mac Docker Desktop)
# or the actual server IP in production.

APP_PROJECT=attome

DATABASE_URL=postgres://postgres:password@localhost:5432/attome_db
REDIS_URL=redis://localhost:6379

JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRY_SECS=86400

SERVER_HOST=0.0.0.0
SERVER_PORT=8080

REQUEST_TIMEOUT_SECS=30
MAX_BODY_SIZE_BYTES=10485760

DB_POOL_SIZE=10
REDIS_POOL_SIZE=5
